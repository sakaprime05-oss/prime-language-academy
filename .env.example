# 1. Obtenez votre URL PostgreSQL sur Neon.tech.
# 2. Remplacez la valeur ci-dessous par votre propre URL.
DATABASE_URL="postgresql://utilisateur:mot_de_passe@ep-xxx-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# --- Authentification ---
# En local, gardez une URL locale. En production, utilisez le domaine public.
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="votre_secret_genere_avec_openssl"
AUTH_TRUST_HOST="true"

# --- Email ---
EMAIL_USER="votre_email@gmail.com"
EMAIL_APP_PASSWORD="votre_mot_de_passe_application_gmail"

# --- Notifications ---
N8N_PLA_NOTIFICATIONS_WEBHOOK="https://votre-n8n/webhook/pla-notifications"

# --- Paiement ---
PAYSTACK_SECRET_KEY="sk_test_xxx"
PAYTECH_API_KEY="votre_api_key_paytech"
PAYTECH_API_SECRET="votre_api_secret_paytech"
PAYTECH_ENV="test"
ADMIN_BOT_KEY="une_cle_longue_et_aleatoire"
CRON_SECRET="une_autre_cle_longue_et_aleatoire"

# --- PawaPay Configuration ---
PAWAPAY_API_TOKEN="votre_token_pawapay"
PAWAPAY_BASE_URL="https://api.sandbox.pawapay.io"
PAWAPAY_CURRENCY="XOF"
PAWAPAY_COUNTRY="CIV"
